        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/extract_learnings.py\"",
            "timeout": 180
          }
        ]
      }
    ],
    "SessionStart": [
      {
